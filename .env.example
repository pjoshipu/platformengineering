# Copy to .env for local dev, or set these in the Vercel project settings.
# NOTE: VITE_-prefixed vars are inlined into the public browser bundle — never
# put a real secret in a VITE_ var in production.

# --- Vercel (production) ---
# Server-side OpenAI key used by the /api/openai serverless proxy. NOT VITE_-prefixed,
# so it never reaches the browser. Set this in Vercel → Project → Environment Variables.
OPENAI_API_KEY=sk-your-server-side-key

# Point the frontend at the same-origin serverless proxy (keeps the key server-side).
VITE_OPENAI_PROXY_URL=/api/openai

# --- Local dev alternative ---
# For `npm run dev` you can instead let the Vite dev server proxy /openai to OpenAI
# and provide a client key (dev only). Leave VITE_OPENAI_PROXY_URL unset in that case.
# VITE_OPENAI_API_KEY=sk-your-dev-key

# --- Optional: Supabase (Edge Functions + run history) ---
# VITE_SUPABASE_URL=
# VITE_SUPABASE_PUBLISHABLE_KEY=
# VITE_SUPABASE_FUNCTIONS_BASE_URL=
